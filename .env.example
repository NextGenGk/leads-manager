# ─── Database (Neon) ───────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/bhilai_leads?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/bhilai_leads?sslmode=require"

# ─── Clerk Auth ────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── NVIDIA NIM ─────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx

# ─── Inngest ───────────────────────────────────────────
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=signkey-prod-xxx

# ─── Apify (Instagram scraping) ────────────────────────
# Get from https://apify.com — free tier: 5 USD/month
APIFY_TOKEN=apify_api_xxx

# ─── Google Maps (optional, for Places enrichment) ─────
GOOGLE_MAPS_API_KEY=AIzaXXX

# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Seed data flag ────────────────────────────────────
# Set to "true" to auto-seed the 12 known leads on first run
SEED_KNOWN_LEADS=true
