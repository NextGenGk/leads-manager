// prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Core business / lead record
// ─────────────────────────────────────────
model Business {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Identity
  name          String
  slug          String   @unique
  category      Category @default(CAFE)
  segment       Segment  @default(BUDGET)
  openingDate   DateTime?
  openingNote   String?  // "Late 2025", "Grand opening Apr 26"

  // Location
  address       String?
  area          String
  city          City     @default(BHILAI)
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  googlePlaceId String?  @unique

  // Contact
  phone         String?
  whatsapp      String?
  email         String?

  // Website
  hasWebsite    Boolean  @default(false)
  websiteUrl    String?
  websiteType   WebsiteType?
  websiteScore  Int?     @default(0) // 1–10
  mobileFriendly Boolean?
  hasReservation Boolean @default(false)
  hasOnlineMenu  Boolean @default(false)

  // Google Business
  googleRating    Float?
  googleReviews   Int?
  googlePhotos    Int?
  googleCategory  String?
  googleBizUrl    String?
  googleDescription String?

  // Lead scoring
  leadScore     Int      @default(0)
  priority      Priority @default(MEDIUM)
  status        LeadStatus @default(NEW)

  // Relations
  instagramProfile  InstagramProfile?
  scrapeHistory     ScrapeRun[]
  emailDrafts       OutreachEmail[]
  notes             LeadNote[]
  dailySnapshots    DailySnapshot[]
  discoveredVia     DiscoverySource?

  @@index([city])
  @@index([priority])
  @@index([leadScore])
  @@index([status])
}

// ─────────────────────────────────────────
// Instagram profile (1-to-1 with Business)
// ─────────────────────────────────────────
model InstagramProfile {
  id              String   @id @default(cuid())
  businessId      String   @unique
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  username        String   @unique
  fullName        String?
  bio             String?
  profileUrl      String
  profilePicUrl   String?

  followers       Int      @default(0)
  following       Int      @default(0)
  postsCount      Int      @default(0)
  isVerified      Boolean  @default(false)
  isBusinessAcct  Boolean  @default(false)

  firstPostDate   DateTime?
  lastPostDate    DateTime?
  engagementLevel EngagementLevel @default(LOW)
  avgLikes        Float?
  avgComments     Float?

  // Latest posts (stored as JSON array)
  recentPosts     Json?    // Post[]

  fetchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
}

// ─────────────────────────────────────────
// Food blogger / content creator
// Used to discover new cafés via their posts
// ─────────────────────────────────────────
model FoodBlogger {
  id          String   @id @default(cuid())
  username    String   @unique
  fullName    String?
  city        City
  followers   Int      @default(0)
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  postsScraped Int     @default(0)
  leadsFound   Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────
// Hashtag tracker
// ─────────────────────────────────────────
model TrackedHashtag {
  id          String   @id @default(cuid())
  tag         String   @unique  // without #
  city        City?
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  postsFound  Int      @default(0)

  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────
// Scrape run log
// ─────────────────────────────────────────
model ScrapeRun {
  id           String      @id @default(cuid())
  startedAt    DateTime    @default(now())
  completedAt  DateTime?
  status       ScrapeStatus @default(RUNNING)
  source       ScrapeSource
  targetQuery  String      // hashtag, username, or placeId
  businessId   String?
  business     Business?   @relation(fields: [businessId], references: [id])

  totalFound   Int         @default(0)
  newLeads     Int         @default(0)
  updated      Int         @default(0)
  errors       Int         @default(0)
  errorLog     String?

  apifyRunId   String?
  cost         Float?      // Apify compute units

  @@index([status])
  @@index([startedAt])
}

// ─────────────────────────────────────────
// Daily snapshot — track growth over time
// ─────────────────────────────────────────
model DailySnapshot {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())

  googleRating   Float?
  googleReviews  Int?
  igFollowers    Int?
  igPosts        Int?
  igEngagement   Float?
  leadScore      Int?

  @@unique([businessId, date])
  @@index([date])
}

// ─────────────────────────────────────────
// AI-generated outreach emails
// ─────────────────────────────────────────
model OutreachEmail {
  id           String      @id @default(cuid())
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  subject      String
  body         String      @db.Text
  tone         EmailTone
  service      String
  platform     String   @default("EMAIL")
  sentStatus   EmailStatus @default(DRAFT)

  generatedAt  DateTime    @default(now())
  sentAt       DateTime?
  openedAt     DateTime?

  @@index([businessId])
}

// ─────────────────────────────────────────
// CRM notes
// ─────────────────────────────────────────
model LeadNote {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// Discovery sources (how we found this lead)
// ─────────────────────────────────────────
model DiscoverySource {
  id           String   @id @default(cuid())
  businessId   String   @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  source       String   // "hashtag:#bhilaicafe", "blogger:@foodiebhilai", "gmaps:search"
  discoveredAt DateTime @default(now())
  postUrl      String?  // Instagram post that mentioned this café
  snippet      String?  // Caption excerpt
}

// ─────────────────────────────────────────
// Scheduler / cron job log
// ─────────────────────────────────────────
model SchedulerLog {
  id          String   @id @default(cuid())
  jobName     String
  triggeredAt DateTime @default(now())
  status      String
  duration    Int?     // ms
  payload     Json?
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────
enum Category {
  CAFE
  RESTAURANT
  BAKERY
  CLOUD_KITCHEN
  BAR
  OTHER
}

enum Segment {
  PREMIUM
  MID
  BUDGET
}

enum City {
  BHILAI
  DURG
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  LOST
  ON_HOLD
}

enum WebsiteType {
  CUSTOM
  WORDPRESS
  WOOCOMMERCE
  SQUARESPACE
  WIXSITE
  SHOPIFY
  INSTAGRAM_ONLY
  NONE
}

enum EngagementLevel {
  HIGH
  MEDIUM
  LOW
  NONE
}

enum ScrapeStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScrapeSource {
  INSTAGRAM_HASHTAG
  INSTAGRAM_BLOGGER
  INSTAGRAM_PROFILE
  GOOGLE_MAPS
  GOOGLE_MAPS_SEARCH
  MANUAL
}

enum EmailTone {
  FRIENDLY
  FORMAL
  DIRECT
  STORYTELLING
}

enum EmailStatus {
  DRAFT
  READY
  SENT
  OPENED
  REPLIED
  BOUNCED
}
